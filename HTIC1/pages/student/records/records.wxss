.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 头部用户信息 */
.header {
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(24, 144, 255, 0.2);
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.user-info text {
  color: #fff;
  font-size: 28rpx;
}

/* 记录列表样式 */
.record-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  transition: all 0.3s;
}

.record-card:active {
  transform: scale(0.98);
}

.card-header {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2rpx solid #f5f7fa;
}

.leave-type {
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.leave-type.sick {
  background: #fff1f0;
  color: #ff4d4f;
}

.leave-type.personal {
  background: #e6f7ff;
  color: #1890ff;
}

.leave-type.other {
  background: #f6ffed;
  color: #52c41a;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.status-tag.pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-tag.approved {
  background: #f6ffed;
  color: #52c41a;
}

.status-tag.rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

.card-content {
  padding: 30rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.info-item {
  text-align: center;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  display: block;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.reason-section {
  background: #f5f7fa;
  padding: 20rpx;
  border-radius: 12rpx;
}

.reason-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
  display: block;
}

.reason-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.card-actions {
  padding: 20rpx;
  border-top: 2rpx solid #f5f7fa;
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: none;
  transition: all 0.3s;
  background: #f5f7fa;
  color: #666;
  padding: 0 40rpx;
}

.action-btn:active {
  background: #e8e8e8;
}

.btn-icon {
  font-size: 24rpx;
}

/* 空状态样式 */
.empty-state {
  padding: 100rpx 0;
  text-align: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
} 