.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  margin-top: 40rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  color: #333;
  font-weight: 500;
}

.form-container {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.type-switch {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 8rpx;
}

.type-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.type-option.active {
  background: #409eff;
}

.type-option text {
  font-size: 28rpx;
  color: #666;
  margin-left: 8rpx;
}

.type-option.active text {
  color: #fff;
}

.type-icon {
  width: 40rpx;
  height: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 20rpx;
}

.input-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.login-btn {
  width: 100% !important;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  background: #409eff !important;
  margin-top: 20rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.line {
  flex: 1;
  height: 1rpx;
  background: #e4e7ed;
}

.divider-text {
  color: #909399;
  font-size: 24rpx;
  margin: 0 20rpx;
}

.init-btn {
  width: 100% !important;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: #409eff;
  background: #ecf5ff !important;
  border: 1rpx solid #b3d8ff;
} 