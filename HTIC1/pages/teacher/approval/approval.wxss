.page-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 顶部卡片样式 */
.header-card {
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  border-radius: 20rpx;
  padding: 40rpx;
  color: #fff;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(24, 144, 255, 0.2);
}

.avatar-section {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.user-info {
  flex: 1;
}

.user-info .name {
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
  display: block;
}

.user-info .title {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}

.stats-section {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 标签页样式 */
.tabs-container {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.tabs {
  display: flex;
  position: relative;
  padding: 0 30rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  position: relative;
}

.tab text {
  font-size: 30rpx;
  color: #666;
  transition: all 0.3s;
}

.tab.active text {
  color: #1890ff;
  font-weight: 500;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: transparent;
  transition: all 0.3s;
}

.tab.active .tab-line {
  background: #1890ff;
  width: 60rpx;
}

/* 列表样式 */
.applications-list {
  padding-bottom: 40rpx;
}

.application-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  transition: all 0.3s;
}

.application-card:active {
  transform: scale(0.98);
}

.card-header {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2rpx solid #f5f7fa;
}

.student-info {
  flex: 1;
}

.student-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.student-class {
  font-size: 26rpx;
  color: #999;
}

.leave-type {
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.leave-type.sick {
  background: #fff1f0;
  color: #ff4d4f;
}

.leave-type.personal {
  background: #e6f7ff;
  color: #1890ff;
}

.leave-type.other {
  background: #f6ffed;
  color: #52c41a;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.status-tag.approved {
  background: #f6ffed;
  color: #52c41a;
}

.status-tag.rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

.card-content {
  padding: 30rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.info-item {
  text-align: center;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  display: block;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.reason-section {
  background: #f5f7fa;
  padding: 20rpx;
  border-radius: 12rpx;
}

.reason-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
  display: block;
}

.reason-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.card-actions {
  display: flex;
  padding: 20rpx;
  gap: 20rpx;
  border-top: 2rpx solid #f5f7fa;
}

.card-actions.single {
  justify-content: flex-end;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: none;
  transition: all 0.3s;
}

.action-btn.approve {
  background: #f6ffed;
  color: #52c41a;
}

.action-btn.approve:active {
  background: #d9f7be;
}

.action-btn.reject {
  background: #fff1f0;
  color: #ff4d4f;
}

.action-btn.reject:active {
  background: #ffa39e;
}

.action-btn.detail {
  background: #f5f7fa;
  color: #666;
}

.action-btn.detail:active {
  background: #e8e8e8;
}

.btn-icon {
  font-size: 24rpx;
}

/* 空状态样式 */
.empty-state {
  padding: 100rpx 0;
  text-align: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 动画效果 */
.applications-list {
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.3s;
}

.applications-list.active {
  opacity: 1;
  transform: translateY(0);
} 